{
  "expo": {
    "name": "Virtuo",
    "slug": "virtuo-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "virtuo",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-av",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Virtuo to use a profile picture from your library.",
          "microphonePermission": "Allow Virtuo to record your voice for speaking exercises."
        }
      ],
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.virtuo.speaking"
    },
    "android": {
      "package": "com.virtuo.speaking",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    }
  }
}
